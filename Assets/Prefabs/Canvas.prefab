  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Aby wyznaczy\u0107 tras\u0119 wybierz sal\u0119 pocz\u0105tkow\u0105 oraz
    ko\u0144cow\u0105 za pomoc\u0105 przycisk\xF3w w prawym g\xF3rnym rogu ekranu.\n\nWybranie
    opcji \"wybierz z planu\" spowoduje wyznaczenie pocz\u0105tkowego lub ko\u0144cowego
    punktu na bazie obecnie wyznaczonego planu zaj\u0119\u0107. "
